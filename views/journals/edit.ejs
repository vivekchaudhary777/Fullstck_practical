<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Journal | TravelJournal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
    <%- include('../partials/navbar') %>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h2 class="card-title mb-1 fw-bold">Edit Journal Entry</h2>
                        <p class="text-muted mb-4 small">
                            <i class="bi bi-lock-fill"></i>
                            Destination is locked: <strong><%= journal.destination %></strong>
                        </p>
                        <%- include('../partials/flash') %>
                        <form action="/journals/<%= journal._id %>?_method=PUT" method="POST" class="needs-validation" novalidate>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="arrivalDate" class="form-label">Arrival Date</label>
                                    <input type="date" class="form-control" id="arrivalDate" name="journal[arrivalDate]"
                                        value="<%= journal.arrivalDate.toISOString().substring(0,10) %>" required>
                                    <div class="invalid-feedback">Please enter an arrival date.</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="departureDate" class="form-label">Departure Date</label>
                                    <input type="date" class="form-control" id="departureDate" name="journal[departureDate]"
                                        value="<%= journal.departureDate.toISOString().substring(0,10) %>" required>
                                    <div class="invalid-feedback">Departure must be after arrival date.</div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="experience" class="form-label">Experience</label>
                                <textarea class="form-control" id="experience" name="journal[experience]" rows="5" required minlength="10"><%= journal.experience %></textarea>
                                <div class="invalid-feedback">Please write at least 10 characters.</div>
                            </div>
                            <div class="mb-4">
                                <label for="rating" class="form-label">Rating (1–5)</label>
                                <select class="form-select" id="rating" name="journal[rating]" required>
                                    <option value="" disabled>Select a rating...</option>
                                    <option value="1" <%= journal.rating === 1 ? 'selected' : '' %>>1 – Poor</option>
                                    <option value="2" <%= journal.rating === 2 ? 'selected' : '' %>>2 – Fair</option>
                                    <option value="3" <%= journal.rating === 3 ? 'selected' : '' %>>3 – Good</option>
                                    <option value="4" <%= journal.rating === 4 ? 'selected' : '' %>>4 – Very Good</option>
                                    <option value="5" <%= journal.rating === 5 ? 'selected' : '' %>>5 – Excellent</option>
                                </select>
                                <div class="invalid-feedback">Please select a rating.</div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Update Entry</button>
                                <a href="/journals/<%= journal._id %>" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/validation.js"></script>
</body>
</html>
