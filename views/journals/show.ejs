<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= journal.destination %> | TravelJournal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
    <%- include('../partials/navbar') %>
    <div class="container py-5">
        <%- include('../partials/flash') %>
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white py-3">
                        <h3 class="mb-0 fw-bold">
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            <%= journal.destination %>
                        </h3>
                    </div>
                    <div class="card-body p-4">
                        <div class="row mb-3">
                            <div class="col-sm-6">
                                <p class="mb-1 text-muted small">Arrival Date</p>
                                <p class="fw-semibold"><i class="bi bi-calendar-check text-success"></i> <%= journal.arrivalDate.toDateString() %></p>
                            </div>
                            <div class="col-sm-6">
                                <p class="mb-1 text-muted small">Departure Date</p>
                                <p class="fw-semibold"><i class="bi bi-calendar-x text-danger"></i> <%= journal.departureDate.toDateString() %></p>
                            </div>
                        </div>
                        <hr>
                        <p class="mb-1 text-muted small">Experience</p>
                        <p class="fs-6 mb-4"><%= journal.experience %></p>
                        <p class="mb-1 text-muted small">Rating</p>
                        <div class="mb-4">
                            <% for (let i = 1; i <= 5; i++) { %>
                                <i class="bi bi-star<%= i <= journal.rating ? '-fill text-warning' : ' text-muted' %> fs-5"></i>
                            <% } %>
                            <span class="ms-2 text-muted">(<%= journal.rating %>/5)</span>
                        </div>
                        <p class="mb-0 text-muted small">
                            <i class="bi bi-person-circle"></i> By <strong><%= journal.author.username %></strong>
                        </p>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a href="/journals/<%= journal._id %>/edit" class="btn btn-outline-secondary">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form action="/journals/<%= journal._id %>?_method=DELETE" method="POST" class="ms-auto">
                            <button class="btn btn-outline-danger" onclick="return confirm('Delete this entry?')">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                        <a href="/journals" class="btn btn-outline-primary">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
