<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Journals | TravelJournal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
    <%- include('../partials/navbar') %>
    <div class="container py-5">
        <%- include('../partials/flash') %>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">My Travel Journals</h2>
            <a href="/journals/new" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> New Entry
            </a>
        </div>
        <% if (journals.length === 0) { %>
            <div class="text-center py-5">
                <i class="bi bi-journal-x display-1 text-muted"></i>
                <p class="mt-3 text-muted fs-5">No journal entries yet. Start documenting your travels!</p>
                <a href="/journals/new" class="btn btn-primary mt-2">Create Your First Entry</a>
            </div>
        <% } else { %>
            <div class="row g-4">
                <% for (let journal of journals) { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 shadow-sm journal-card">
                            <div class="card-body">
                                <h5 class="card-title fw-bold">
                                    <i class="bi bi-geo-alt-fill text-danger"></i>
                                    <%= journal.destination %>
                                </h5>
                                <p class="text-muted small mb-2">
                                    <i class="bi bi-calendar3"></i>
                                    <%= journal.arrivalDate.toDateString() %> &rarr; <%= journal.departureDate.toDateString() %>
                                </p>
                                <p class="card-text text-truncate"><%= journal.experience %></p>
                                <div class="rating-stars mb-3">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <i class="bi bi-star<%= i <= journal.rating ? '-fill text-warning' : ' text-muted' %>"></i>
                                    <% } %>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent d-flex gap-2">
                                <a href="/journals/<%= journal._id %>" class="btn btn-sm btn-outline-primary">View</a>
                                <a href="/journals/<%= journal._id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form action="/journals/<%= journal._id %>?_method=DELETE" method="POST" class="ms-auto">
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this entry?')">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
